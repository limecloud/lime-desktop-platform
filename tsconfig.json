{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@limecloud/desktop-platform-contracts": ["packages/contracts/src/index.ts"],
      "@limecloud/desktop-platform-react": ["packages/react/src/index.tsx"],
      "@shared/*": ["src/shared/*"],
      "@main/*": ["src/main/*"],
      "@renderer/*": ["src/renderer/src/*"]
    },
    "types": ["node", "electron"]
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx", "packages/**/*.ts"]
}
